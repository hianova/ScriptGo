{
  "productName": "MarkdownNotes",
  "version": "0.1.0",
  "identifier": "com.scriptgo.markdownnotes",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "windows": [
      {
        "title": "ScriptGo Markdown Notes",
        "width": 1024,
        "height": 720,
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": ["icons/icon.png"]
  }
}
